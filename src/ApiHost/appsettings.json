{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PluginHost": {
    "PluginsPath": "plugins",
    "EnableHotReload": true,
    "ScanInterval": "00:00:10",
    "BaseUrl": "http://localhost:5000"
  },
  "Database": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=pluginhost.db"
  }
}